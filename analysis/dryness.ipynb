   "source": [
    "# --- Fixed-background ORA (N = 32,945 genome-wide genes, K = 66 full dPCD module) ---\n",
    "# Pins the ORA background to shared values so this notebook's genomics and\n",
    "# epigenomics tests are directly comparable with the other phenotype notebooks.\n",
    "# Unlike ora()/confusion_table() above, the module is NOT clipped to the variant\n",
    "# universe: N is the fixed genome-wide gene count and K is the full 66-gene dPCD\n",
    "# module, so n / k / expected are read on one common background.\n",
    "N_FIXED, K_FIXED = 32_945, 66\n",
    "\n",
    "\n",
    "def ora_fixed(candidates, module=MODULE_BROAD, N=N_FIXED, K=K_FIXED):\n",
    "    \"\"\"dPCD over-representation on a fixed (N, K) background -- no clipping.\"\"\"\n",
    "    cand = set(candidates)\n",
    "    n = len(cand)\n",
    "    k = len(cand & set(module))\n",
    "    expected = K * n / N\n",
    "    fold = (k / n) / (K / N) if n and K else float(\"nan\")\n",
    "    p = hypergeom.sf(k - 1, N, K, n)                  # P(X >= k)\n",
    "    return pd.Series(dict(N=N, K=K, n=n, k=k, expected=round(expected, 3),\n",
    "                          fold=round(fold, 2), p=p,\n",
    "                          hits=\", \".join(sorted(cand & set(module)))))\n",
    "\n",
    "\n",
    "genomics_cand   = df_genes.loc[df_genes[\"score\"] >= 0.5, \"ann_gene_id\"].dropna()\n",
    "epigenomic_cand = phenotype_candidates[\"gene_label\"].dropna()\n",
    "\n",
    "pd.DataFrame({\n",
    "    \"genomics (score>=0.5)\":      ora_fixed(genomics_cand),\n",
    "    \"epigenomics (promoter DMR)\": ora_fixed(epigenomic_cand),\n",
    "}).T"
   ]
  },
