from datetime import datetime
from pathlib import Path

WDIR        = str(Path(workflow.basedir).parent)
TIMESTAMP   = datetime.now().strftime("%Y%m%d_%H%M%S")
SAMPLES     = ["SBC4", "SBC10", "SBC11", "SBC23"]

config.setdefault("WDIR",  WDIR)

rule all:
    input:
        # main output for direct viewing in IGV
        expand(f"{WDIR}/results/vcf_processing/{{sample}}.phased.vcf.gz", sample=SAMPLES),
        expand(f"{WDIR}/results/vcf_processing/{{sample}}.phased.vcf.gz.csi", sample=SAMPLES),        
        # additional output for annotation
        expand(f"{WDIR}/results/vcf_for_annotation/{{sample}}.renamed.vcf.gz", sample=SAMPLES),
        expand(f"{WDIR}/results/vcf_for_annotation/{{sample}}.renamed.vcf.gz.csi", sample=SAMPLES),

include: "rules/reads_preprocessing.smk"
include: "rules/variant_analysis.smk"
include: "rules/vcf_processing.smk"
