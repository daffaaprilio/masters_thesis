        # expand(f"{PHASED_VCF_DIR}/{{sample}}.phased.vcf.gz.csi", sample=SAMPLES),
        # expand(f"{SIFT_DIR}/{{group}}.sift4g.vcf.gz", group=VARGROUP_LABELS),   # sift_annotation.smk
        # expand(f"{DMR_DIR}/{{pair}}.5mC.DMR.tsv", pair=PAIRS),         # dmr_analysis.smk
        f"{DMR_DIR}/DMR_annotated.tsv",
        # Vanilla Sniffles2 SV result (combined multi-sample VCF; pulls in the
        # per-sample calls). Path string because sv_analysis.smk is included below.
        f"{WDIR}/results/sv_calling/combined.sniffles.vcf.gz",   # sv_analysis.smk


