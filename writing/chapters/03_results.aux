\@writefile{toc}{\contentsline {subsection}{\numberline {3.4.3}Enrichment test}{12}{subsection.3.4.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3.7}{\ignorespaces Hypergeometric over-representation analysis (ORA) of the dPCD module in each omics layer's candidate gene list, for both demonstration phenotypes. All tests share a fixed background of $N = 32{,}945$ annotated sorghum genes containing $K = 66$ dPCD module genes; $n$ is the number of candidate genes, $k$ the number of module genes among them, and the expected count, fold enrichment, and $p$-value (hypergeometric survival, $P(X \geq k)$) follow. Only the variant layer for stem extra juiciness reaches significance ($p < 0.05$, in bold).}}{13}{table.caption.14}\protected@file@percent }
\newlabel{tab:ora-enrichment}{{3.7}{13}{Hypergeometric over-representation analysis (ORA) of the dPCD module in each omics layer's candidate gene list, for both demonstration phenotypes. All tests share a fixed background of $N = 32{,}945$ annotated sorghum genes containing $K = 66$ dPCD module genes; $n$ is the number of candidate genes, $k$ the number of module genes among them, and the expected count, fold enrichment, and $p$-value (hypergeometric survival, $P(X \geq k)$) follow. Only the variant layer for stem extra juiciness reaches significance ($p < 0.05$, in bold)}{table.caption.14}{}}
